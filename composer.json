{
    "name": "cloudcastle/di",
    "description": "Lightweight PSR-11 dependency injection container for PHP 8.3+. Autowiring, declarative configuration (PHP/JSON/YAML/XML), directory scan, custom inject attributes, tagged services, decorators. Лёгкий DI-контейнер с autowiring, конфигурацией из файлов и scan, одна зависимость psr/container.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "cloudcastle",
        "container",
        "dependency-injection",
        "dependency-injection-container",
        "di",
        "di-container",
        "injection",
        "ioc",
        "ioc-container",
        "lightweight",
        "micro",
        "minimal",
        "php8",
        "php83",
        "psr-11",
        "psr11",
        "autowiring",
        "service-container",
        "composition-root",
        "configuration",
        "container-configuration",
        "yaml",
        "json",
        "xml",
        "inject",
        "attributes",
        "freeze",
        "lazy-loading",
        "decorator",
        "tagged-services",
        "php-di",
        "pimple",
        "symfony-di"
    ],
    "authors": [
        {
            "name": "CloudCastle",
            "homepage": "https://github.com/cloudcastle-apps"
        }
    ],
    "homepage": "https://packagist.org/packages/cloudcastle/di",
    "support": {
        "issues": "https://github.com/cloudcastle-apps/di/issues",
        "source": "https://github.com/cloudcastle-apps/di",
        "docs": "https://github.com/cloudcastle-apps/di/wiki"
    },
    "require": {
        "php": "^8.3",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "deptrac/deptrac": "^3.0 || ^4.0",
        "ergebnis/composer-normalize": "^2.45",
        "friendsofphp/php-cs-fixer": "^3.75",
        "icanhazstring/composer-unused": "^0.9",
        "infection/infection": "^0.29 || ^0.33",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpdocumentor/shim": "^3.7",
        "phpmd/phpmd": "^2.15",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5",
        "psalm/plugin-phpunit": "^0.19",
        "rector/rector": "^2.0",
        "roave/security-advisories": "dev-latest",
        "squizlabs/php_codesniffer": "^3.12 || ^4.0",
        "vimeo/psalm": "^6.0"
    },
    "suggest": {
        "ext-yaml": "Загрузка YAML-конфигурации контейнера (ContainerConfigurator)"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "CloudCastle\\DI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CloudCastle\\DI\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Fixtures/Autowire/Scan/MultiScanPair.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "php-http/discovery": true,
            "phpdocumentor/shim": true,
            "phpstan/extension-installer": true
        },
        "audit": {
            "abandoned": "ignore"
        },
        "fund": false,
        "platform": {
            "php": "8.3.31"
        },
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.5-dev"
        }
    },
    "scripts": {
        "analyse": [
            "@phpstan",
            "@psalm"
        ],
        "benchmark-report": "@php tools/benchmark-report.php --markdown",
        "check": [
            "@lint",
            "@analyse",
            "@phpcs",
            "@phpmd",
            "@deptrac",
            "@test"
        ],
        "ci": [
            "@ci:meta",
            "@ci:linters",
            "@ci:static-analysis",
            "@ci:tests",
            "@docs:check"
        ],
        "ci:linters": [
            "@lint",
            "@cs-check",
            "@phpcs"
        ],
        "ci:meta": [
            "@ci:prepare",
            "@composer-normalize-check",
            "@deps-audit",
            "@unused"
        ],
        "ci:prepare": "@php -r \"foreach (['var/cache', 'var/cache/phpstan', 'var/cache/infection', 'var/cache/phpdoc', 'var/coverage', 'var/infection'] as \\$dir) { is_dir(\\$dir) || mkdir(\\$dir, 0777, true); }\"",
        "ci:static-analysis": [
            "@phpstan",
            "@psalm",
            "@phpmd",
            "@deptrac",
            "@rector"
        ],
        "ci:tests": [
            "@test:unit",
            "@test:integration",
            "@test:security",
            "@test:load",
            "@test:performance",
            "@test:coverage",
            "@test:mutation"
        ],
        "composer-normalize": "composer normalize",
        "composer-normalize-check": "composer normalize --dry-run",
        "coverage-check": "@php tools/coverage-check.php var/coverage/clover.xml",
        "cs-check": "php-cs-fixer fix --dry-run --diff --verbose",
        "cs-fix": "php-cs-fixer fix --verbose",
        "deps-audit": "composer audit --no-ansi",
        "deptrac": "deptrac analyse --fail-on-uncovered --report-uncovered",
        "docs": "bash bin/generate-docs.sh",
        "docs:check": "bash bin/generate-docs.sh",
        "infection": "infection --quiet --threads=max --show-mutations --min-msi=95 --min-covered-msi=95",
        "lint": "parallel-lint --colors src tests",
        "phpcbf": "phpcbf",
        "phpcs": "phpcs",
        "phpmd": "phpmd src,tests text phpmd.xml",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "phpunit": "phpunit",
        "psalm": "psalm --no-cache --no-progress",
        "rector": "rector process --dry-run",
        "rector-fix": "rector process",
        "test": [
            "@test:unit",
            "@test:integration",
            "@test:security",
            "@test:load"
        ],
        "test:coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit --configuration phpunit.coverage.xml.dist --coverage-text --coverage-clover var/coverage/clover.xml",
            "@coverage-check"
        ],
        "test:integration": "phpunit --testsuite integration",
        "test:load": "phpunit --testsuite load",
        "test:mutation": "@infection",
        "test:performance": "phpunit --testsuite performance",
        "test:security": "phpunit --testsuite security",
        "test:unit": "phpunit --testsuite unit",
        "unused": "composer-unused"
    },
    "scripts-descriptions": {
        "analyse": "Статический анализ: PHPStan + Psalm",
        "benchmark-report": "Markdown-отчёт фактических времён бенчмарков",
        "check": "Полный набор проверок качества перед коммитом",
        "ci": "Полный CI-пайплайн: meta → linters → static-analysis → tests",
        "ci:linters": "CI: синтаксис, PHP CS Fixer, PHPCS",
        "ci:meta": "CI: normalize, audit, unused",
        "ci:prepare": "Создание каталогов кэша для инструментов качества",
        "ci:static-analysis": "CI: PHPStan, Psalm, PHPMD, Deptrac, Rector",
        "ci:tests": "CI: unit, integration, security, load, performance, coverage, mutation",
        "composer-normalize": "Нормализация composer.json",
        "composer-normalize-check": "Проверка нормализации composer.json",
        "coverage-check": "Проверка clover-отчёта на покрытие строк (≥95%)",
        "cs-check": "Проверка стиля кода без изменений",
        "cs-fix": "Автоисправление стиля кода",
        "deps-audit": "Проверка уязвимостей зависимостей (composer audit)",
        "deptrac": "Проверка архитектурных слоёв",
        "docs": "Генерация API-документации в docs/",
        "docs:check": "Проверка сборки API-документации",
        "infection": "Мутационное тестирование (алиас test:mutation)",
        "lint": "Проверка синтаксиса PHP",
        "phpcbf": "Автоисправление PHPCS",
        "phpcs": "Проверка стандарта кодирования PSR-12",
        "phpmd": "PHP Mess Detector",
        "phpstan": "Статический анализ PHPStan",
        "phpunit": "Запуск unit-тестов",
        "psalm": "Статический анализ Psalm",
        "rector": "Проверка правил рефакторинга (dry-run)",
        "rector-fix": "Применение правил рефакторинга",
        "test": "PHPUnit: unit + integration + security + load",
        "test:coverage": "PHPUnit с проверкой покрытия строк (≥95%)",
        "test:integration": "Интеграционные тесты",
        "test:load": "Нагрузочные тесты",
        "test:mutation": "Мутационные тесты (Infection)",
        "test:performance": "Тесты производительности (PHPUnit)",
        "test:security": "Тесты безопасности",
        "test:unit": "Unit-тесты",
        "unused": "Поиск неиспользуемых зависимостей"
    }
}
