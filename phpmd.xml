<?xml version="1.0"?>
<ruleset name="CloudCastle DI PHPMD"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>Правила PHP Mess Detector для CloudCastle DI</description>

    <rule ref="rulesets/cleancode.xml">
        <exclude name="StaticAccess"/>
    </rule>
    <rule ref="rulesets/codesize.xml">
        <exclude name="TooManyPublicMethods"/>
        <exclude name="ExcessiveClassComplexity"/>
        <exclude name="TooManyFields"/>
        <exclude name="TooManyMethods"/>
    </rule>
    <rule ref="rulesets/codesize.xml/TooManyPublicMethods">
        <exclude-pattern>*/tests/*</exclude-pattern>
        <properties>
            <property name="maxmethods" value="20"/>
            <property name="ignorepattern" value="(^(set|get|is|has|with|enable|disable|make|alias|lazy|bind|call|add|after|tag|decorat|autowire|scan|freeze|dump|register|profile|reset))i"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveClassComplexity">
        <properties>
            <property name="maximum" value="78"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/TooManyFields">
        <properties>
            <property name="maxfields" value="20"/>
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/TooManyMethods">
        <properties>
            <property name="maxmethods" value="35"/>
        </properties>
    </rule>
    <rule ref="rulesets/controversial.xml">
        <exclude name="Superglobals"/>
    </rule>
    <rule ref="rulesets/design.xml">
        <exclude name="CouplingBetweenObjects"/>
    </rule>
    <rule ref="rulesets/naming.xml">
        <exclude name="ShortVariable">
            <property name="exceptions" value="id"/>
        </exclude>
    </rule>
    <rule ref="rulesets/unusedcode.xml"/>
</ruleset>
